{
    "name": "perimeter-control-ha-integration",
    "version": "1.0.0",
    "description": "Perimeter Control: Home Assistant custom card for Isolator edge nodes, fleet view, and deploy-from-HA",
    "main": "dist/ha-integration.js",
    "type": "module",
    "scripts": {
        "build": "rollup -c rollup.config.js && npm run copy-to-integration",
        "copy-to-integration": "cpx dist/ha-integration.js ../frontend/",
        "watch": "rollup -c rollup.config.js --watch",
        "dev": "ROLLUP_WATCH=true rollup -c rollup.config.js --watch",
        "lint": "eslint src",
        "clean": "rimraf dist"
    },
    "keywords": [
        "home-assistant",
        "custom-card",
        "isolator",
        "web-component",
        "lit",
        "hacs",
        "edge",
        "raspberry-pi",
        "network-isolator"
    ],
    "author": "Paul Avgerinos",
    "license": "MIT",
    "dependencies": {
        "lit": "^3.0.0"
    },
    "devDependencies": {
        "@rollup/plugin-node-resolve": "^15.0.0",
        "@rollup/plugin-terser": "^0.4.4",
        "@rollup/plugin-typescript": "^11.0.0",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "rimraf": "^5.0.0",
        "rollup": "^4.0.0",
        "tslib": "^2.6.0",
        "typescript": "^5.0.0"
    }
}