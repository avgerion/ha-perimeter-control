[Unit]
Description=PerimeterControl Web Dashboard
After=network.target {SUPERVISOR_SERVICE}.service
Wants={SUPERVISOR_SERVICE}.service

[Service]
Type=simple
User=root
Group=root
WorkingDirectory={WEB_DIR}
Environment="PYTHONUNBUFFERED=1"
ExecStart={VENV}/bin/python3 {WEB_DIR}/dashboard.py
Restart=on-failure
RestartSec=10

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={STATE_ROOT} {LOG_ROOT}

[Install]
WantedBy=multi-user.target