{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy Dashboard",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/deploy-dashboard-web.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "tab": "Deploy"
      },
      "problemMatcher": []
    },
    {
      "label": "Deploy Dashboard (No Restart)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/deploy-dashboard-web.ps1",
        "-NoRestart"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "tab": "Deploy"
      },
      "problemMatcher": []
    },
    {
      "label": "Open SSH Tunnel (port ${config:perimeterControl.dashboard.port})",
      "type": "shell",
      "command": "ssh",
      "args": [
        "-i",
        "${config:perimeterControl.remote.sshKey}",
        "-N",
        "-L",
        "${config:perimeterControl.dashboard.port}:localhost:${config:perimeterControl.dashboard.port}",
        "${config:perimeterControl.remote.user}@${config:perimeterControl.remote.host}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "tab": "SSH Tunnel"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^$",
          "endsPattern": "^$"
        }
      }
    },
    {
      "label": "Open Dashboard in Browser",
      "type": "shell",
      "command": "Start-Process",
      "args": [
        "http://localhost:${config:perimeterControl.dashboard.port}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build HA Integration",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ha-integration"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "tab": "HA Build"
      },
      "problemMatcher": [
        {
          "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+)\\s+(warning|error)\\s+(TS\\d+):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "code": 5,
            "message": 6
          }
        }
      ]
    },
    {
      "label": "Watch HA Integration",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "watch"
      ],
      "options": {
        "cwd": "${workspaceFolder}/ha-integration"
      },
      "group": "build",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "tab": "HA Watch"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+)\\s+(warning|error)\\s+(TS\\d+):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^rollup",
          "endsPattern": "(created|updated)\\s+.*\\.js"
        }
      }
    },
    {
      "label": "Tunnel + Open Browser",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Open SSH Tunnel (port ${config:perimeterControl.dashboard.port})",
        "Open Dashboard in Browser"
      ],
      "group": "none",
      "problemMatcher": []
    }
  ]
}